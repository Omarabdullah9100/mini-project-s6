# ============================================================
# Cybersecurity Detection Framework — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# SerpAPI Key (replaces Google Custom Search API)
# Get yours at: https://serpapi.com/
SERPAPI_KEY=your-serpapi-key-here

# Email / SMTP Configuration (for sending CERT-In reports)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
CERT_IN_EMAIL=vdisclose@cert-in.org.in

# Database
DATABASE_URL=sqlite:///./cybersecurity.db

# Application Settings
DEBUG=True
HOST=0.0.0.0
PORT=8000
